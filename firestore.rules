rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard Helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprint for Reservation - strict format controls
    function isValidReservation(data) {
      return data.keys().hasAll(['id', 'resourceId', 'date', 'startTime', 'endTime', 'purpose', 'status', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.resourceId is string && data.resourceId.size() <= 128
        && data.date is string && data.date.size() <= 32
        && data.startTime is string && data.startTime.size() <= 10
        && data.endTime is string && data.endTime.size() <= 10
        && data.purpose is string && data.purpose.size() <= 1000
        && data.status is string && data.status in ['pending', 'confirmed', 'in_use', 'completed', 'cancelled']
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000))
        && (!('attendees' in data) || data.attendees is int);
    }

    match /reservations/{reservationId} {
      // Allows viewing reservations without a login wall to prevent double-booking conflicts
      allow get, list: if true;
      
      // Validates reservation schema and temporal integrity on creation
      allow create: if isValidId(reservationId)
        && isValidReservation(incoming())
        && incoming().createdAt == request.time;

      // Validates reservation schema and state transit rules on update
      allow update: if isValidId(reservationId)
        && isValidReservation(incoming())
        && existing().status != 'completed'
        && existing().status != 'cancelled';

      allow delete: if false;
    }
  }
}
